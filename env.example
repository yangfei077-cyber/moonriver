# Auth0 Configuration
AUTH0_SECRET='use [openssl rand -hex 32] to generate a 32 bytes value'
AUTH0_DOMAIN='your-tenant.us.auth0.com'
AUTH0_CLIENT_ID='your-client-id'
AUTH0_CLIENT_SECRET='your-client-secret'
AUTH0_AUDIENCE='https://your-api-identifier'
AUTH0_SCOPE='openid profile email offline_access'
APP_BASE_URL='http://localhost:3000'

# Auth0 Management API (for role management)
AUTH0_MANAGEMENT_CLIENT_ID='your-management-client-id'
AUTH0_MANAGEMENT_CLIENT_SECRET='your-management-client-secret'

# OpenRouter API Key for AI Assistant / RAG
OPENROUTER_API_KEY='your-openrouter-api-key'
NEXT_PUBLIC_APP_URL='http://localhost:3000'

# Google Calendar (via Auth0 Token Vault / Connected Accounts)
# 1. Add Google social connection in Auth0 Dashboard
# 2. Enable "Offline Access" in Connection Permissions for the connection
# 3. Create My Account API: identifier https://YOUR_DOMAIN/me/, scope create:me:connected_accounts
# 4. Enable Token Vault grant type for your application

# Auth0 FGA (Fine-Grained Authorization) — Optional
# Enables granular permission checks for RAG data access.
# If not configured, the system falls back to role-based permissions.
#
# Setup:
# 1. Go to Auth0 Dashboard > Fine Grained Authorization (or https://dashboard.fga.dev)
# 2. Create a new store (e.g., "moonriver")
# 3. Deploy the authorization model from fga/model.json
# 4. Create a client credential for API access
# 5. Write initial tuples for your test accounts (see below)
#
# FGA_API_URL='https://api.us1.fga.dev'          # US region (or api.eu1.fga.dev for EU)
# FGA_STORE_ID='your-fga-store-id'               # From FGA Dashboard > Store Settings
# FGA_MODEL_ID='your-authorization-model-id'     # From FGA Dashboard after deploying model
# FGA_CLIENT_ID='your-fga-client-id'             # From FGA Dashboard > Settings > Credentials
# FGA_CLIENT_SECRET='your-fga-client-secret'     # From FGA Dashboard > Settings > Credentials
# FGA_API_TOKEN_ISSUER='fga.us.auth0.com'        # Token issuer for your region
# FGA_API_AUDIENCE='https://api.us1.fga.dev/'    # API audience for your region
#
# Initial tuples for test accounts (run via FGA Dashboard or CLI):
#   fga tuple write user:admin@moonriver.com admin platform:moonriver
#   fga tuple write user:creator@moonriver.com creator course:any
#   fga tuple write user:student@moonriver.com student course:any

# Neon PostgreSQL (required for production)
# Get your connection string from https://neon.tech
DATABASE_URL='postgresql://user:password@host/database?sslmode=require'
